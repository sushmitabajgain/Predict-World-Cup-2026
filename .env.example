APP_NAME="World Cup Predictor"
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://worldcup:worldcup@postgres:5432/worldcup
REDIS_URL=redis://redis:6379/0
MLFLOW_TRACKING_URI=http://mlflow:5000
CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001","http://127.0.0.1:3001"]'
XGBOOST_MODEL_VERSION=xgboost-v1
USE_REAL_DATASET=true
REAL_DATASET_PATH=app/data/international_results.csv
TRAINING_MATCH_LIMIT=1000
SEED_DEMO_DATA=true
VITE_API_URL=http://localhost:8000
